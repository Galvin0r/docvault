<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.23.xsd">

    <changeSet id="1" author="Roman">
        <createTable tableName="roles">
            <column name="id" type="BIGINT">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="created" type="TIMESTAMPTZ"/>
            <column name="last_modified" type="TIMESTAMPTZ"/>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="2" author="Roman">
        <createTable tableName="users">
            <column name="id" type="BIGINT">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="created" type="TIMESTAMPTZ"/>
            <column name="last_modified" type="TIMESTAMPTZ"/>
            <column name="login" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="password" type="VARCHAR(255)"/>
            <column name="email" type="VARCHAR(255)"/>
            <column name="enabled" type="BOOLEAN">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="3" author="Roman">
        <createTable tableName="activation_tokens">
            <column name="id" type="BIGINT">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="token" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMPTZ"/>
            <column name="expires_at" type="TIMESTAMPTZ">
                <constraints nullable="false"/>
            </column>
            <column name="validated_at" type="TIMESTAMPTZ"/>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addForeignKeyConstraint
                constraintName="fk_activation_tokens_user"
                baseTableName="activation_tokens"
                baseColumnNames="user_id"
                referencedTableName="users"
                referencedColumnNames="id"/>
    </changeSet>

    <changeSet id="4" author="Roman">
        <createTable tableName="users_roles">
            <column name="user_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="role_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addPrimaryKey
                columnNames="user_id, role_id"
                tableName="users_roles"/>
        <addForeignKeyConstraint
                constraintName="fk_users_roles_user"
                baseTableName="users_roles"
                baseColumnNames="user_id"
                referencedTableName="users"
                referencedColumnNames="id"/>
        <addForeignKeyConstraint
                constraintName="fk_users_roles_role"
                baseTableName="users_roles"
                baseColumnNames="role_id"
                referencedTableName="roles"
                referencedColumnNames="id"/>
    </changeSet>
    
    <changeSet id="5" author="Roman">
        <createSequence sequenceName="users_seq"/>
        <createSequence sequenceName="roles_seq"/>
        <createSequence sequenceName="activation_tokens_seq"/>
    </changeSet>

    <changeSet id="6" author="Roman">
        <createTable tableName="refresh_tokens">
            <column name="id" type="BIGINT">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="token" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="expires_at" type="TIMESTAMPTZ">
                <constraints nullable="false"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="device_info" type="VARCHAR(255)" />
        </createTable>
        <addForeignKeyConstraint
                constraintName="fk_refresh_tokens_user"
                baseTableName="refresh_tokens"
                baseColumnNames="user_id"
                referencedTableName="users"
                referencedColumnNames="id"/>
        <createSequence sequenceName="refresh_tokens_seq"/>
    </changeSet>
    <changeSet id="7" author="Roman">
        <addColumn tableName="users">
            <column name="oauth2_provider" type="varchar(10)"/>
        </addColumn>
    </changeSet>
    <changeSet id="8" author="Roman">
        <dropNotNullConstraint tableName="users" columnName="email"/>
    </changeSet>

    <changeSet id="9" author="Roman">
        <addUniqueConstraint tableName="activation_tokens"
                             columnNames="user_id"
                             constraintName="uq_activation_tokens_user"/>
        <addUniqueConstraint tableName="refresh_tokens"
                             columnNames="user_id, device_info"
                             constraintName="uq_user_device_unique"/>
    </changeSet>

    <changeSet id="10" author="Roman">
        <createTable tableName="groups">
            <column name="id" type="BIGINT">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="created" type="TIMESTAMPTZ"/>
            <column name="last_modified" type="TIMESTAMPTZ"/>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="11" author="Roman">
        <createTable tableName="group_membership">
            <column name="id" type="BIGINT">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="created" type="TIMESTAMPTZ"/>
            <column name="last_modified" type="TIMESTAMPTZ"/>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="group_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="role" type="VARCHAR(40)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="group_membership"
                baseColumnNames="user_id"
                referencedTableName="users"
                referencedColumnNames="id"
                constraintName="fk_membership_user"/>

        <addForeignKeyConstraint
                baseTableName="group_membership"
                baseColumnNames="group_id"
                referencedTableName="groups"
                referencedColumnNames="id"
                constraintName="fk_membership_group"
                onDelete="CASCADE"/>
    </changeSet>
    
    <changeSet id="12" author="Roman">
        <createTable tableName="documents">
            <column name="id" type="BIGINT">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="created" type="TIMESTAMPTZ"/>
            <column name="last_modified" type="TIMESTAMPTZ"/>
            <column name="title" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="TEXT"/>
            <column name="original_filename" type="VARCHAR(255)" />
            <column name="path" type="VARCHAR(500)" />
            <column name="mime_type" type="VARCHAR(100)" />
            <column name="visibility" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="owner_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="size_bytes" type="BIGINT" />
            <column name="status" type="VARCHAR(10)">
                <constraints nullable="false" />
            </column>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="documents"
                baseColumnNames="owner_id"
                referencedTableName="users"
                referencedColumnNames="id"
                constraintName="fk_documents_owner"/>
    </changeSet>
    
    <changeSet id="13" author="Roman">
        <createTable tableName="document_access">
            <column name="id" type="BIGINT">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="created" type="TIMESTAMPTZ"/>
            <column name="last_modified" type="TIMESTAMPTZ"/>
            <column name="document_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="user_id" type="BIGINT"/>
            <column name="group_id" type="BIGINT"/>
            <column name="permission" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="document_access"
                baseColumnNames="document_id"
                referencedTableName="documents"
                referencedColumnNames="id"
                constraintName="fk_docaccess_document"/>

        <addForeignKeyConstraint
                baseTableName="document_access"
                baseColumnNames="user_id"
                referencedTableName="users"
                referencedColumnNames="id"
                constraintName="fk_docaccess_user"/>

        <addForeignKeyConstraint
                baseTableName="document_access"
                baseColumnNames="group_id"
                referencedTableName="groups"
                referencedColumnNames="id"
                constraintName="fk_docaccess_group"/>
    </changeSet>
    
    <changeSet id="14" author="Roman">
        <createSequence sequenceName="groups_seq"/>
        <createSequence sequenceName="documents_seq"/>
        <createSequence sequenceName="document_access_seq"/>
        <createSequence sequenceName="group_membership_seq"/>
    </changeSet>

    <changeSet id="15" author="Roman">
        <createTable tableName="password_reset_tokens">
            <column name="id" type="BIGINT">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="token" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="expires_at" type="TIMESTAMPTZ">
                <constraints nullable="false"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addForeignKeyConstraint
                constraintName="fk_password_reset_tokens_user"
                baseTableName="password_reset_tokens"
                baseColumnNames="user_id"
                referencedTableName="users"
                referencedColumnNames="id"/>
    </changeSet>

    <changeSet id="16" author="Roman">
        <addUniqueConstraint tableName="password_reset_tokens"
                              columnNames="user_id"
                              constraintName="uq_password_reset_tokens_user"/>
    </changeSet>

    <changeSet id="17" author="Roman">
        <createSequence sequenceName="password_reset_tokens_seq"/>
    </changeSet>

    <changeSet id="18" author="Roman">
        <addColumn tableName="groups">
            <column name="visibility" type="VARCHAR(30)" defaultValue="public">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="VARCHAR(200)" />
        </addColumn>
    </changeSet>

    <changeSet id="19" author="Roman">
        <createTable tableName="group_join_requests">
            <column name="id" type="BIGINT">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="created" type="TIMESTAMPTZ"/>
            <column name="last_modified" type="TIMESTAMPTZ"/>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="group_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(20)" defaultValue="PENDING">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="group_join_requests"
                baseColumnNames="user_id"
                referencedTableName="users"
                referencedColumnNames="id"
                constraintName="fk_join_request_user"/>

        <addForeignKeyConstraint
                baseTableName="group_join_requests"
                baseColumnNames="group_id"
                referencedTableName="groups"
                referencedColumnNames="id"
                constraintName="fk_join_request_group"
                onDelete="CASCADE"/>

        <createSequence sequenceName="group_join_requests_seq" />
    </changeSet>

    <changeSet id="20" author="Roman">

        <createTable tableName="document_index_jobs">
            <column name="id" type="BIGINT">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="created" type="TIMESTAMPTZ"/>
            <column name="last_modified" type="TIMESTAMPTZ"/>
            <column name="document_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="locked_by" type="VARCHAR(36)" />
            <column name="lock_until" type="TIMESTAMPTZ" />
            <column name="attempts" type="INT" defaultValueNumeric="0">
                <constraints nullable="false" />
            </column>
            <column name="last_error" type="VARCHAR(200)"/>
            <column name="status" type="VARCHAR(10)">
                <constraints nullable="false" />
            </column>
            <column name="next_attempt_at" type="TIMESTAMPTZ" />
        </createTable>

        <addForeignKeyConstraint
                baseTableName="document_index_jobs"
                baseColumnNames="document_id"
                referencedTableName="documents"
                referencedColumnNames="id"
                constraintName="fk_indexjobs_document"/>

        <createSequence sequenceName="document_index_jobs_seq" />
    </changeSet>

    <changeSet id="22" author="Roman">
        <createIndex indexName="idx_index_jobs_status_next" tableName="document_index_jobs">
            <column name="status"/>
            <column name="next_attempt_at"/>
        </createIndex>

        <createIndex indexName="idx_index_jobs_lock_until" tableName="document_index_jobs">
            <column name="lock_until"/>
        </createIndex>
    </changeSet>

    <include file="db.insert-data.xml" relativeToChangelogFile="true" />
</databaseChangeLog>